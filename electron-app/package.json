{
  "name": "tg-bot-deploy",
  "version": "1.2.2",
  "description": "TG Bot Cloudflare 部署工具",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "blake3-wasm": "^2.1.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.tgbot.deploy",
    "productName": "TG Bot 部署工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../worker.js",
        "to": "worker.js"
      },
      {
        "from": "../wrangler.toml",
        "to": "wrangler.toml"
      },
      {
        "from": "../migrations",
        "to": "migrations"
      },
      {
        "from": "node_modules/blake3-wasm",
        "to": "node_modules/blake3-wasm"
      },
      {
        "from": "../admin-panel",
        "to": "admin-panel",
        "filter": [
          "**",
          "!dist/**",
          "!.env*",
          "!node_modules/.cache/**",
          "!node_modules/.vite/**"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/blake3-wasm/**",
      "admin-panel/node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "artifactName": "tg-bot-deploy-setup.exe"
    }
  }
}
